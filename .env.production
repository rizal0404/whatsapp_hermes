NODE_ENV=production
PORT=3000
API_KEY=generate-a-secure-random-key-here
DATABASE_URL=postgresql://postgres:secure-password-here@postgres:5432/wa_gateway?schema=public
REDIS_URL=redis://redis:6379
WA_AUTH_DIR=/app/auth
QR_TTL_SECONDS=30
MAX_RETRY_ATTEMPTS=3
MESSAGE_JOB_TTL_SECONDS=3600
MAX_FILE_SIZE_MB=20
ALLOWED_FILE_DOMAINS=raw.githubusercontent.com,internal.example.com
LOG_LEVEL=info
