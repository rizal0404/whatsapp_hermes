NODE_ENV=development
PORT=3000
API_KEY=your-secure-api-key-here
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wa_gateway?schema=public
REDIS_URL=redis://localhost:6379
WA_AUTH_DIR=./auth
QR_TTL_SECONDS=30
MAX_RETRY_ATTEMPTS=3
MESSAGE_JOB_TTL_SECONDS=3600
MAX_FILE_SIZE_MB=20
ALLOWED_FILE_DOMAINS=internal.example.com,storage.example.com,raw.githubusercontent.com
LOG_LEVEL=debug
