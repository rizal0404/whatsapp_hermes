NODE_ENV=development
PORT=3000
API_KEY=your-secure-api-key-here

# Database credentials for Postgres container
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=wa_gateway
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wa_gateway?schema=public
REDIS_URL=redis://localhost:6379
WA_AUTH_DIR=./auth
QR_TTL_SECONDS=30
MAX_RETRY_ATTEMPTS=3
MESSAGE_JOB_TTL_SECONDS=3600
MAX_FILE_SIZE_MB=20
ALLOWED_FILE_DOMAINS=internal.example.com,storage.example.com,raw.githubusercontent.com
LOG_LEVEL=debug

# Webhook configuration
WEBHOOK_URL=http://localhost:3000/webhook-test
HERMES_WEBHOOK_URL=http://localhost:3000/v1/hermes/incoming-webhook
WEBHOOK_MAX_RETRIES=5
WEBHOOK_RETRY_DELAY_MS=5000
INCOMING_POLL_INTERVAL_MS=300000

